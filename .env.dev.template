# Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=autonomy
MYSQL_USER=autonomy_user
MYSQL_PASSWORD=autonomy_password
MYSQL_HOST=db

# Application Configuration
SECRET_KEY=dev_secret_key_123
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Backend Configuration
DEBUG=true
ENVIRONMENT=development

# Frontend Configuration
REACT_APP_API_URL=/api

# LLM Configuration — points at the mss1-max lab gateway by default.
# See Autonomy-Core/docs/dev/MSS1_MAX_LAB_ACCESS.md for setup, key
# distribution, and smoke-tests. Source-of-truth design lives in
# Autonomy-Core/docs/architecture/LLM_ARCHITECTURE.md §11.

# Shared lab API key — paste from mss1-max:/home/trevor/lab-llm/api.env
# OR from your team secret manager (1Password / Bitwarden). Required for
# every gateway request; do not commit a real value.
LLM_LAB_API_KEY=

# Workload-split endpoints (preferred — see LLM_ARCHITECTURE.md §3.2).
LLM_NARRATION_API_BASE=http://mss1-max.local:8080/v1/narration
LLM_NARRATION_MODEL_NAME=gpt-oss-120b
LLM_CHAT_API_BASE=http://mss1-max.local:8080/v1/chat
LLM_CHAT_MODEL_NAME=qwen3-30b-a3b
LLM_EMBEDDINGS_API_BASE=http://mss1-max.local:8080/v1/embeddings
LLM_EMBEDDINGS_MODEL_NAME=nomic-embed-text-v1.5

# Legacy aliases for callers not yet migrated to the workload split
# (MIGRATION_REGISTER §3.16). Point at the same gateway.
LLM_API_BASE=http://mss1-max.local:8080/v1/chat
LLM_API_KEY=${LLM_LAB_API_KEY}
LLM_MODEL_NAME=qwen3-30b-a3b
AUTONOMY_ENABLE_SUPERVISOR=true
AUTONOMY_ENABLE_GLOBAL_AGENT=false
