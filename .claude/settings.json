{
  "permissions": {
    "allow": [
      "Bash(make logs)",
      "Bash(make up)",
      "Bash(make up-dev)",
      "Bash(make down)",
      "Bash(make restart-backend)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull --ff-only)",
      "Bash(git push)",
      "Bash(alembic current)",
      "Bash(alembic history:*)",
      "Bash(alembic heads)",
      "Bash(alembic show:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -c:*)"
    ],
    "deny": [
      "Bash(make rebuild-db)",
      "Bash(make db-reset)",
      "Bash(make reseed-db)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(docker volume rm:*)",
      "Bash(docker system prune:*)",
      "Bash(git remote add upstream*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-bash.sh"
          }
        ]
      }
    ]
  }
}
