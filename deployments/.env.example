# ---------------------------------------------------------------------------
# Autonomy TMS — deployment-time port allocation
# ---------------------------------------------------------------------------
# Copy to repo root as `.env` (Compose auto-loads) or pass explicitly via
#   docker compose --env-file deployments/your-deployment.env up -d
#
# Defaults baked into docker-compose.yml are the values below. Override
# only if you need to colocate with another Autonomy variant on the same
# host or avoid a port already used by something else.
#
# See Autonomy-Core/docs/DEPLOYMENT_PORTS.md for the cross-product
# convention (SCP defaults + how to add new variants).
# ---------------------------------------------------------------------------

# --- TMS defaults (shifted off SCP to allow colocation) ---
PROXY_HOST_PORT=8089
FRONTEND_HOST_PORT=3001
BACKEND_HOST_PORT=8010
PGADMIN_HOST_PORT=5051
MCP_HOST_PORT=8011
DEV_TLS_HOST_PORT=8444
MARIADB_HOST_PORT=3308

# --- If you'd rather TMS take the SCP slot (no SCP on this host) ---
# PROXY_HOST_PORT=8088
# FRONTEND_HOST_PORT=3000
# BACKEND_HOST_PORT=8000
# PGADMIN_HOST_PORT=5050
# MCP_HOST_PORT=8001
# DEV_TLS_HOST_PORT=8443
# MARIADB_HOST_PORT=3307

# --- Customer demo on shared infra example ---
# PROXY_HOST_PORT=18089
# BACKEND_HOST_PORT=18010
# (etc. — bump everything by +10000 to clear of standard local usage)
