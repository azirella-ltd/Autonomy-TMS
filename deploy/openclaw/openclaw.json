{
  "agent": {
    "model": "qwen3-8b",
    "providers": {
      "custom": {
        "api_key": "${LLM_API_KEY:-not-needed}",
        "api_base": "${LLM_API_BASE:-http://vllm:8000/v1}"
      }
    },
    "max_tokens": 4096,
    "temperature": 0.1
  },
  "channels": {
    "slack": {
      "enabled": false,
      "bot_token": "${SLACK_BOT_TOKEN}",
      "allow_from": ["planning-team", "supply-chain-ops"],
      "alert_channel": "#supply-chain-alerts"
    },
    "teams": {
      "enabled": false,
      "webhook_url": "${TEAMS_WEBHOOK_URL}"
    },
    "whatsapp": {
      "enabled": false,
      "phone_number_id": "${WHATSAPP_PHONE_ID}",
      "access_token": "${WHATSAPP_ACCESS_TOKEN}"
    }
  },
  "autonomy": {
    "api_base": "${AUTONOMY_API_BASE:-http://backend:8000}",
    "service_token": "${OPENCLAW_SERVICE_TOKEN}"
  }
}
