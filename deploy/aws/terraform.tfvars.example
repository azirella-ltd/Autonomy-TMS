# ---------------------------------------------------------------------------
# Example terraform.tfvars — Copy to terraform.tfvars and customize
# ---------------------------------------------------------------------------

aws_region   = "us-east-1"
project_name = "autonomy"
environment  = "dev"

# SSH key pair (must exist in AWS)
ssh_key_name = "my-ec2-keypair"

# Restrict SSH to your IP (recommended)
allowed_ssh_cidrs = ["YOUR_IP/32"]
allowed_web_cidrs = ["0.0.0.0/0"]

# Autonomy instance
autonomy_instance_type = "t3.xlarge"    # 4 vCPU, 16 GB — $0.17/hr
autonomy_volume_size   = 100            # GB

# SAP S/4HANA instance
# Leave empty to skip SAP provisioning (deploy Autonomy first)
sap_ami_id       = ""                   # Set after SAP CAL export
sap_instance_type = "r5.4xlarge"        # 16 vCPU, 128 GB — $3.02/hr
sap_volume_size   = 500                 # GB

# SAP auto start/stop schedule (UTC)
sap_auto_schedule_enabled = true
sap_schedule_start = "cron(0 13 ? * MON-FRI *)"  # 8 AM ET
sap_schedule_stop  = "cron(0 1 ? * MON-FRI *)"   # 8 PM ET
